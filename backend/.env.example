# Copy this file to .env and fill in your values

# PostgreSQL — from Supabase project settings > Database
# Use the Transaction Pooler URL (Settings > Database > Connection string > Transaction)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-1-us-west-2.pooler.supabase.com:6543/postgres

# OpenAI — from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Clerk — from https://dashboard.clerk.com > API Keys
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...

# Supabase — from project settings > API
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Optional overrides (defaults shown)
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSIONS=1536
# CHAT_MODEL=gpt-4o-mini
# CHUNK_SIZE=800
# CHUNK_OVERLAP=100
# TOP_K_RESULTS=5
# DEBUG=false
